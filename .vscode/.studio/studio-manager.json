{
  "rules": [
    {
      "condition": "always",
      "commandType": "vscode",
      "command": "studio-manager.openFile README.md 1"
    },
    {
      "condition": "always",
      "commandType": "vscode",
      "command": "studio-manager.openSimpleBrowser https://${STUDIO_HOST_ID}-5173.${STUDIO_HOST}",
      "delay": 2000
    },
    {
      "condition": "always",
      "commandType": "vscode",
      "command": "studio-manager.openTerminal",
      "cmdArgs": [
        "npm install && npm run dev",
        {
          "name": "nextjs",
          "location": 1
        }
      ],
      "delay": 500
    }
  ],
  "simpleBrowserDefaultAppUrl": "https://${STUDIO_HOST_ID}-5173.${STUDIO_HOST}"
}